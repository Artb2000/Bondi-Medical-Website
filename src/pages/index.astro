---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookNowButton from '../components/BookNowButton.astro';
import { siteCopy } from '../content/siteCopy';
import { siteConfig } from '../config/site';

const copy = siteCopy.home;
---

<BaseLayout
	title={copy.title}
	description={copy.description}
>
	<Fragment slot="hero">
		<section class="hero shell">
			<div>
				<p class="kicker">{copy.hero.eyebrow}</p>
				<h1>{copy.hero.heading}</h1>
				<p>
					{copy.hero.intro}
				</p>
				<div class="hero-actions">
					<BookNowButton context="home_hero" />
					<a href={`tel:${siteConfig.phoneHref}`} data-track="phone_click" class="ghost-link">
						{copy.hero.secondaryCta}
					</a>
				</div>
			</div>
			<img src="/images/reception.jpg" alt="Bondi Medical reception area" loading="eager" />
		</section>
	</Fragment>

	<Fragment slot="intro">
		<section class="shell section-block">
			<h2>{copy.intro.title}</h2>
			<p>
				{copy.intro.body}
			</p>
		</section>
	</Fragment>

	<Fragment slot="contentSections">
		<section class="shell section-block">
			<div class="section-head">
				<h2>{copy.featuredServices.title}</h2>
				<a href="/services">See all services</a>
			</div>
			<div class="card-grid services-grid">
				<article class="service-card">
					<h3>{copy.featuredServices.cards[0].title}</h3>
					<p>
						{copy.featuredServices.cards[0].body}
					</p>
				</article>
				<article class="service-card">
					<h3>{copy.featuredServices.cards[1].title}</h3>
					<p>
						{copy.featuredServices.cards[1].body}
					</p>
				</article>
				<article class="service-card">
					<h3>{copy.featuredServices.cards[2].title}</h3>
					<p>
						{copy.featuredServices.cards[2].body}
					</p>
				</article>
			</div>
		</section>

		<section class="shell section-block">
			<h2>{copy.locationTeaser.title}</h2>
			<p>
				{copy.locationTeaser.body}
			</p>
			<p>
				{copy.locationTeaser.support}
			</p>
		</section>
	</Fragment>

	<Fragment slot="ctaStrip">
		<section class="shell contact-band">
			<h2>{copy.closingCta.title}</h2>
			<p>
				{copy.closingCta.body}
			</p>
			<BookNowButton context="home_closing" />
		</section>
	</Fragment>

	<Fragment slot="seo">
		<meta name="robots" content="index,follow" />
	</Fragment>

	<section class="shell section-block">
		<div class="section-head">
			<h2>Need to speak to the clinic?</h2>
			<a href="/contact">Contact / Location</a>
		</div>
		<p>
			Call <a href={`tel:${siteConfig.phoneHref}`} data-track="phone_click">(02) 9389 7667</a> or
			email <a href={`mailto:${siteConfig.email}`} data-track="email_click">{siteConfig.email}</a>.
		</p>
	</section>
</BaseLayout>
