---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookNowButton from '../components/BookNowButton.astro';
import FeeTable from '../components/FeeTable.astro';
import SidebarCard from '../components/SidebarCard.astro';
import { siteCopy } from '../content/siteCopy';

const copy = siteCopy.fees;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
>
  <Fragment slot="hero">
    <section class="shell section-block">
      <p class="kicker">Fees</p>
      <h1>{copy.hero.heading}</h1>
      <p>
        {copy.hero.intro}
      </p>
    </section>
  </Fragment>

  <Fragment slot="contentSections">
    <section id="book-now" class="shell section-block">
      <h2>{copy.bookNow.title}</h2>
      <p>
        {copy.bookNow.body}
      </p>
      <BookNowButton context="fees_book_now" />
    </section>

    <section class="shell section-block page-two-col">
      <div>
        <h2>{copy.standardFees.title}</h2>
        <p>{copy.standardFees.body}</p>
        <FeeTable
          caption="Standard GP fee table"
          columns={copy.standardFees.table.columns}
          rows={copy.standardFees.table.rows}
        />

        <h2>{copy.skinFees.title}</h2>
        <p>{copy.skinFees.body}</p>
        <FeeTable
          caption="Skin clinic fee table"
          columns={copy.skinFees.table.columns}
          rows={copy.skinFees.table.rows}
        />

        <h2>{copy.additionalFees.title}</h2>
        <p>{copy.additionalFees.body}</p>
        <p>{copy.additionalFees.support}</p>
      </div>

      <div class="sidebar-stack">
        <SidebarCard title={copy.hours.title}>
          <ul class="hours-list">
            <li><span>Monday to Friday</span><strong>{copy.hours.mondayToFriday}</strong></li>
            <li><span>Saturday</span><strong>{copy.hours.saturday}</strong></li>
            <li><span>Sunday</span><strong>{copy.hours.sunday}</strong></li>
          </ul>
        </SidebarCard>

        <SidebarCard title={copy.afterHours.title}>
          <p>{copy.afterHours.body}</p>
        </SidebarCard>
      </div>
    </section>
  </Fragment>

  <Fragment slot="ctaStrip">
    <section class="shell contact-band">
      <h2>{copy.cta.title}</h2>
      <p>{copy.cta.body}</p>
      <BookNowButton context="fees_closing" />
    </section>
  </Fragment>
</BaseLayout>
