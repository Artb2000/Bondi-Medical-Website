---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BookNowButton from '../components/BookNowButton.astro';
import { siteCopy } from '../content/siteCopy';
import { services } from '../config/site';

const copy = siteCopy.services;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
>
  <Fragment slot="hero">
    <section class="shell section-block">
      <p class="kicker">Services</p>
      <h1>{copy.hero.heading}</h1>
      <p>
        {copy.hero.intro}
      </p>
    </section>
  </Fragment>

  <Fragment slot="contentSections">
    <section class="shell card-grid services-grid section-block">
      {services.map((service) => <ServiceCard service={service} />)}
    </section>
  </Fragment>

  <Fragment slot="ctaStrip">
    <section class="shell contact-band">
      <h2>{copy.cta.title}</h2>
      <p>{copy.cta.body}</p>
      <BookNowButton context="services_page" />
    </section>
  </Fragment>
</BaseLayout>
