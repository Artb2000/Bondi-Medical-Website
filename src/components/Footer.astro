---
import { siteConfig } from '../config/site';
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <section>
      <h2>{siteConfig.name}</h2>
      <p>{siteConfig.addressLine1}</p>
      <p>{siteConfig.addressLine2}</p>
      <p>{siteConfig.addressLine3}</p>
    </section>

    <section>
      <h2>Contact</h2>
      <p>
        <a href={`tel:${siteConfig.phoneHref}`} data-track="phone_click">
          {siteConfig.phoneDisplay}
        </a>
      </p>
      <p>
        <a href={`mailto:${siteConfig.email}`} data-track="email_click">
          {siteConfig.email}
        </a>
      </p>
      <p>{siteConfig.hoursSummary}</p>
    </section>
  </div>
</footer>
