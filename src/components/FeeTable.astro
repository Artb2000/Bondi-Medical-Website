---
interface Column {
  key: string;
  label: string;
}

interface Row {
  [key: string]: string;
}

interface Props {
  caption: string;
  columns: readonly Column[];
  rows: readonly Row[];
}

const { caption, columns, rows } = Astro.props;
---

<table class="fees-table">
  <caption>{caption}</caption>
  <thead>
    <tr>
      {columns.map((column) => <th scope="col">{column.label}</th>)}
    </tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          {columns.map((column) => <td>{row[column.key] ?? '-'}</td>)}
        </tr>
      ))
    }
  </tbody>
</table>
