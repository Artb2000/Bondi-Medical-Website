---
interface Column {
  key: string;
  label: string;
}

interface Row {
  [key: string]: string;
}

interface Props {
  columns: readonly Column[];
  rows: readonly Row[];
}

const { columns, rows } = Astro.props;
---

<div class="fees-table-wrap">
  <table class="fees-table">
    <thead>
      <tr>
        {columns.map((column) => <th scope="col">{column.label}</th>)}
      </tr>
    </thead>
    <tbody>
      {
        rows.map((row) => (
          <tr>
            {columns.map((column) => <td>{row[column.key] ?? '-'}</td>)}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
