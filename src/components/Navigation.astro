---
import BookNowButton from './BookNowButton.astro';
import { siteConfig } from '../config/site';

const normalizePath = (path: string) => {
  if (path.length > 1 && path.endsWith('/')) {
    return path.slice(0, -1);
  }

  return path;
};

const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
  <div class="shell nav-shell">
    <a href="/" class="brand" aria-label="Bondi Medical Centre home">
      <img src="/bmc.svg" alt="" class="brand-logo" aria-hidden="true" />
      <span>
        <strong>{siteConfig.shortName}</strong>
        <small>Bondi Junction NSW</small>
      </span>
    </a>

    <nav aria-label="Main navigation" class="main-nav">
      <ul>
        {
          siteConfig.navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={currentPath === normalizePath(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header-actions">
      <BookNowButton className="header-cta" context="header" />
      <a href={`tel:${siteConfig.phoneHref}`} data-track="phone_click" class="call-btn header-call-btn">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M19.2 14.4c-1.3 0-2.5-.2-3.7-.7-.4-.1-.8 0-1 .3l-2.3 2.3c-2.9-1.5-5.3-3.9-6.8-6.8l2.3-2.3c.3-.3.4-.7.3-1-.5-1.2-.7-2.4-.7-3.7 0-.6-.4-1-1-1H2.8c-.6 0-1 .4-1 1C1.8 13.8 10.2 22.2 21.2 22.2c.6 0 1-.4 1-1v-3.8c0-.6-.4-1-1-1z" />
        </svg>
        <span>Call</span>
      </a>
    </div>
  </div>
</header>
